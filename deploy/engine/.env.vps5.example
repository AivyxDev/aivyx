# Aivyx Engine — VPS5 Autonomous Agents Environment
# Copy to .env and fill in values before deploying.

# Domain
ENGINE_DOMAIN=vps5.aivyx-engine.cloud
ACME_EMAIL=admin@aivyx-engine.cloud

# Database (auto-generated on first deploy)
DB_PASSWORD=
REDIS_PASSWORD=

# Engine secrets
# Generate with: openssl rand -hex 32
JWT_SECRET=
AIVYX_PASSPHRASE=

# LLM Provider — Ollama (local, no external API key needed)
AIVYX_API_KEY=ollama
