{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for Aivyx metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Error Rate by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval])) by (status)",
          "legendFormat": "{{ status }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[$__rate_interval])) by (status)",
          "legendFormat": "{{ status }}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate by Endpoint",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "scaleDistribution": { "type": "linear" }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": {
          "xBuckets": { "mode": "size", "value": "1m" }
        },
        "color": {
          "scheme": "Oranges"
        },
        "yAxis": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"[45]..\"}[$__rate_interval])) by (path)",
          "legendFormat": "{{ path }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_rejected_total[$__rate_interval])) by (tier)",
          "legendFormat": "{{ tier }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Chaos Fault Injections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(chaos_faults_total[$__rate_interval])) by (type)",
          "legendFormat": "{{ type }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Federation Relay Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(federation_relay_errors_total[$__rate_interval])) by (peer, error)",
          "legendFormat": "{{ peer }} ({{ error }})",
          "refId": "A"
        },
        {
          "expr": "sum(rate(federation_relay_total[$__rate_interval])) by (peer)",
          "legendFormat": "{{ peer }} (total)",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["aivyx", "errors", "reliability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Aivyx Error Rates",
  "uid": "aivyx-error-rates",
  "version": 1
}
